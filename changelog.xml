<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
          http://www.liquibase.org/xml/ns/dbchangelog
          http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="1-create-users-table" author="student">
        <createTable tableName="users">
            <column name="id" type="INT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="username" type="VARCHAR(100)">
                <constraints nullable="false" unique="true"/>
            </column>
            <column name="email" type="VARCHAR(150)"/>
        </createTable>
    </changeSet>

    <changeSet id="2-insert-sample-users" author="student">
        <insert tableName="users">
            <column name="username" value="alice"/>
            <column name="email" value="alice@example.com"/>
        </insert>
        <insert tableName="users">
            <column name="username" value="bob"/>
            <column name="email" value="bob@example.com"/>
        </insert>
    </changeSet>

    <changeSet id="3-add-created-at-column" author="student">
        <addColumn tableName="users">
            <column name="created_at" type="DATETIME" defaultValueComputed="CURRENT_TIMESTAMP"/>
        </addColumn>
    </changeSet>

</databaseChangeLog>